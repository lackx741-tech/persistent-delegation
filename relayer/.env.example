# Relayer Backend Environment Variables

# ─── Sponsor wallet (holds ETH to pay gas) ───────────────────────────────────
# NEVER commit real private keys. Use Anvil test key for local dev.
SPONSOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── RPC endpoint ─────────────────────────────────────────────────────────────
# Local: http://127.0.0.1:8545
# Production: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_URL=http://127.0.0.1:8545

# ─── Chain ID ──────────────────────────────────────────────────────────────────
# 31337 = Anvil local | 11155111 = Sepolia | 1 = Mainnet
CHAIN_ID=31337

# ─── BatchCallAndSponsor contract address ─────────────────────────────────────
IMPLEMENTATION_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ─── Telegram alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── 1Shot API (production gasless relayer) ───────────────────────────────────
# Sign up at https://1shotapi.com — get your API key
ONE_SHOT_API_KEY=your_1shot_api_key_here
ONE_SHOT_RELAYER_URL=https://relayer.1shotapi.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
